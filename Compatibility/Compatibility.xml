<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">

	<!-- Server Compatibility System
	     Loads server-specific patches for CleanerChat.
	     To add support for a new server, create a file in Servers/ and register it.
	     See Servers/_Template.lua for instructions. -->

	<!-- Main compatibility loader (provides registration API) -->
	<Script file="Compatibility.lua"/>

	<!-- Server-specific patches (order doesn't matter - detection is automatic) -->
	<Script file="Servers\Native.lua"/>
	<Script file="Servers\Ascension.lua"/>

	<!-- Template is not loaded - it's just for reference -->
	<!-- <Script file="Servers\_Template.lua"/> -->

</Ui>
